-- Auto generated by rsplug
local event2modules = { <% for (event, modules) in event2modules {%>['<%=event%>']={<% for module in modules { %>'<%=module%>',<%}%>},<%}%> }
for event, modules in pairs(event2modules) do
	vim.api.nvim_create_autocmd(event, {
		callback = function()
			for _, module_id in ipairs(modules) do
				require(module_id)
			end
		end,
	})
end
