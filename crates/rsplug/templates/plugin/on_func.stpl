-- Auto generated by rsplug
<% for func in funcs {%><% if func.is_autoload() { %>
vim.api.nvim_create_autocmd('FuncUndefined', { pattern = '<%= func %>', once = true, callback = function() require'_rsplug/on_func'.autoload_handler('<%= func %>') end })
<% } else { %>vim.cmd(([[
function! <%= func %>(...) abort
  return luaeval("require'_rsplug/on_func'.func_handler(_A[1], _A[2])", ['<%= func %>', a:000])
endfunction
]]))
<% } } %>
